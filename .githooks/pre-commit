#!/bin/bash
# Pre-commit hook: detecta secretos antes de hacer commit

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
FOUND=0

for FILE in $STAGED_FILES; do
  [[ "$FILE" == *.example ]] && continue
  [[ "$FILE" == *.png || "$FILE" == *.jpg || "$FILE" == *.jar || "$FILE" == *.class ]] && continue

  CONTENT=$(git show ":$FILE" 2>/dev/null)

  # Detectar credenciales hardcodeadas en application.properties
  if echo "$CONTENT" | grep -qiE "datasource\.(username|password)=[^$\{]"; then
    echo "SECRETO DETECTADO en $FILE (credencial de DB hardcodeada)"
    FOUND=1
  fi

  # Detectar tokens AWS
  if echo "$CONTENT" | grep -qE "AKIA[0-9A-Z]{16}"; then
    echo "SECRETO DETECTADO en $FILE (AWS Access Key)"
    FOUND=1
  fi

  # Detectar API keys de OpenAI/Anthropic
  if echo "$CONTENT" | grep -qE "sk-[a-zA-Z0-9]{32,}"; then
    echo "SECRETO DETECTADO en $FILE (API key)"
    FOUND=1
  fi

  # Detectar archivos .env con valores reales commiteados
  if [[ "$FILE" == *".env" && "$FILE" != *".env.example" ]]; then
    echo "ARCHIVO .env DETECTADO: $FILE - no debe commitearse"
    FOUND=1
  fi
done

if [ $FOUND -ne 0 ]; then
  echo ""
  echo "Commit bloqueado. Mueve los secretos a archivos .env y usa variables de entorno."
  exit 1
fi

exit 0
