#!/bin/bash
# Pre-commit hook: detecta secretos antes de hacer commit

PATTERNS=(
  "password\s*=\s*['\"]?[^${\s'\"][^'\"]{3,}"
  "passwd\s*=\s*['\"]?[^${\s'\"][^'\"]{3,}"
  "secret\s*=\s*['\"]?[^${\s'\"][^'\"]{3,}"
  "api[_-]?key\s*=\s*['\"]?[^${\s'\"][^'\"]{3,}"
  "token\s*=\s*['\"]?[^${\s'\"][^'\"]{3,}"
  "AKIA[0-9A-Z]{16}"
  "sk-[a-zA-Z0-9]{32,}"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
FOUND=0

for FILE in $STAGED_FILES; do
  # Ignorar archivos de ejemplo y binarios
  [[ "$FILE" == *.example ]] && continue
  [[ "$FILE" == *.png || "$FILE" == *.jpg || "$FILE" == *.jar ]] && continue

  for PATTERN in "${PATTERNS[@]}"; do
    MATCH=$(git show ":$FILE" 2>/dev/null | grep -iP "$PATTERN" || true)
    if [ -n "$MATCH" ]; then
      echo "❌ SECRETO DETECTADO en $FILE:"
      echo "   $MATCH"
      FOUND=1
    fi
  done
done

if [ $FOUND -ne 0 ]; then
  echo ""
  echo "⛔ Commit bloqueado. Mueve los secretos a archivos .env y usa variables de entorno."
  exit 1
fi

exit 0
